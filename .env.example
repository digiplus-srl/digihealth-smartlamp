# DigiHealth Lamp - variabili d'ambiente (copia in .env e compila)
# NON committare il file .env reale.

# --- InfluxDB Cloud (scrittura dati sensori) ---
# IMPORTANTE: il vecchio token era hard-coded nel codice ed e' finito su git:
# va RUOTATO/revocato dal pannello InfluxDB e sostituito qui.
INFLUXDB_TOKEN=metti-qui-il-nuovo-token

# --- API key per gli endpoint di ingestion esposti via Cloudflare Tunnel ---
# Usata sia come "Authorization: Bearer <token>" sia come "X-Api-Key: <token>".
# Genera un valore robusto, es: python -c "import secrets; print(secrets.token_urlsafe(32))"
DIGIHEALTH_API_KEY=metti-qui-una-chiave-robusta

# --- Telegram Bot (notifiche alert) ---
# Ottieni il token da @BotFather su Telegram.
# Il chat_id può essere un utente (positivo) o un gruppo (negativo).
TELEGRAM_BOT_TOKEN=metti-qui-il-token-del-bot
TELEGRAM_CHAT_ID=metti-qui-il-chat-id
