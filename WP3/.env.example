# ============================================================
# Copia questo file in .env e compila tutti i valori.
# Il file .env non deve mai essere committato su git.
# ============================================================

# --- InfluxDB ---
INFLUX_URL=https://your-influxdb-host/
INFLUX_TOKEN=your-influxdb-token
INFLUX_ORG=your-org-name
INFLUX_BUCKET=health_data
INFLUX_SETTINGS_BUCKET=health_settings
INFLUX_MEASUREMENT=ZPHSensor_sensore

# --- API service ---
API_SERVICE_PORT=8000
RULE_SERVICE_PORT=8010
WP3_MODEL_DIR=/app/output/phase3_v5

# --- CRM (sistema di terze parti) ---
# URL base del CRM (senza slash finale)
THIRD_PARTY_BASE_URL=https://your-crm-host/
# Token utente per il login CRM (/api/token)
THIRD_PARTY_USER_TOKEN=your-crm-user-token
THIRD_PARTY_COMPANY_ID=0
# ID categorie alert nel CRM
THIRD_PARTY_ALARM_CATEGORY_ID=0
THIRD_PARTY_TOLERANCE_CATEGORY_ID=0
THIRD_PARTY_PREDICTIVE_CATEGORY_ID=0
# Mapping device ID (lampada) -> asset ID nel CRM
# Formato JSON: {"mac-address-o-serial":asset_id_intero}
THIRD_PARTY_ASSET_ID_MAP={"device1":1,"device2":2}

# --- DigiHealth (opzionale) ---
# Se non utilizzato, lasciare vuoto
DIGIHEALTH_ALERT_URL=
DIGIHEALTH_API_KEY=
DIGIHEALTH_LAMP1_ALERT_URL=
DIGIHEALTH_LAMP1_API_KEY=
DIGIHEALTH_LAMP1_LAMPS=
DIGIHEALTH_TIMEOUT_SECONDS=15

# --- Comportamento rule service ---
THIRD_PARTY_ALERT_TIMEZONE=Europe/Rome
PREDICTIVE_TTT_MAX_MINUTES=15
PREDICTIVE_ALERT_COOLDOWN_MINUTES=60
ALERT_BATCH_WINDOW_MS=5000
